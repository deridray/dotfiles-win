{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "color": {"1": "#80d4d5", "2": "#b0cccb"},
        "source": "~/.config/fastfetch/ascii/rose.txt",
        "padding": {
            "top": 2,
            "right": 6
        }
    },
    "display": {
        "color": {"keys": "#80d4d5", "title": "#b0cccb"},
        "separator": " "
    },
    "modules": [
	"break",
	"break",
	{
            "type": "title",
            "keyWidth": 10
        },
        "break",
        {
            "type": "os",
            "key": " ",
        },
        {
            "type": "uptime",
            "format": "{hours}h {minutes}m",
            "key": " ",
        },
        {
            "type": "packages",
            "key": " ",  
        },
        {
            "type": "cpu",
            "format": "{name}",
            "key": " ", 
        },
        {
            "type": "gpu",
            "format": "{name}",
            "key": " ",
        },
        {
            "type": "memory",
            "key": " ", 
        },
        {
            "type": "media",
            "key": "󰝚 ", 
        },
        "break",
        {
            "key": " ",
            "type": "colors",
            "symbol": "circle"
        },
        "break",
        "break",
        "break",
    ]
}
